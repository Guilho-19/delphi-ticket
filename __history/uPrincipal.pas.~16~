    Exit
  end;

  ADOQuery2.Filter := 'titulo like ' + QuotedStr('%' + edtPesquisaTicketsTitulo.Text + '%');
  ADOQuery2.Filtered := True;
end;

procedure TfrmPrincipal.edtPesquisaTicketsModuloChange(Sender: TObject);
begin
  if Trim(edtPesquisaTicketsModulo.Text) = '' then
  begin
    ADOQuery2.Filtered := False;
    Exit
  end;

  ADOQuery2.Filter := 'modulo like ' + QuotedStr('%' + edtPesquisaTicketsModulo.Text + '%');
  ADOQuery2.Filtered := True;
end;

procedure TfrmPrincipal.edtPesquisaTicketsEmpresaChange(Sender: TObject);
begin
  if Trim(edtPesquisaTicketsEmpresa.Text) = '' then
  begin
    ADOQuery2.Filtered := False;
    Exit
  end;

  ADOQuery2.Filter := 'empresa like ' + QuotedStr('%' + edtPesquisaTicketsEmpresa.Text + '%');
  ADOQuery2.Filtered := True;
end;

end.
