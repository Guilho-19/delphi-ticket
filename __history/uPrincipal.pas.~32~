    dmConexao.qryTickets.Filtered := False;
    Exit;
  end;

  dmConexao.qryTickets.Filter := 'responsavel like ' + QuotedStr('%' + edtPesquisaTicketsResponsavel.Text + '%');
  dmConexao.qryTickets.Filtered := True;
